{"captainVersion":4,"services":{"$$cap_appname-init":{"image":"alpine:3.20","restart":"no","command":["sh","-c","set -e\nchown -R 1000:0 /files\nchmod -R u+rwX /files\nsleep 100d\n"],"user":"root","volumes":["$$cap_appname-files:/files"],"caproverExtra":{"notExposeAsWebApp":true}},"$$cap_appname":{"image":"vikunja/vikunja:$$cap_vikunja_version","environment":{"VIKUNJA_SERVICE_PUBLICURL":"$$cap_public_url","VIKUNJA_SERVICE_SECRET":"$$cap_service_secret","VIKUNJA_SERVICE_TIMEZONE":"$$cap_timezone","VIKUNJA_SERVICE_ENABLEREGISTRATION":"$$cap_enable_registration","VIKUNJA_DATABASE_TYPE":"postgres","VIKUNJA_DATABASE_HOST":"srv-captain--$$cap_appname-db","VIKUNJA_DATABASE_USER":"$$cap_db_user","VIKUNJA_DATABASE_PASSWORD":"$$cap_db_password","VIKUNJA_DATABASE_DATABASE":"$$cap_db_name"},"volumes":["$$cap_appname-files:/app/vikunja/files"],"depends_on":["$$cap_appname-init","$$cap_appname-db"],"caproverExtra":{"containerHttpPort":"3456"}},"$$cap_appname-db":{"image":"paradedb/paradedb:$$cap_paradedb_version","environment":{"POSTGRES_USER":"$$cap_db_user","POSTGRES_PASSWORD":"$$cap_db_password","POSTGRES_DB":"$$cap_db_name"},"volumes":["$$cap_appname-db-data:/var/lib/postgresql"],"caproverExtra":{"notExposeAsWebApp":true}}},"caproverOneClickApp":{"variables":[{"id":"$$cap_vikunja_version","label":"Vikunja Version","defaultValue":"2.3","description":"Vikunja Docker image tag. See https://hub.docker.com/r/vikunja/vikunja/tags","validRegex":"/.{1,}/"},{"id":"$$cap_paradedb_version","label":"ParadeDB Version","defaultValue":"0.23.1-pg18","description":"ParadeDB Docker image tag. This default uses PostgreSQL 18, which requires the data volume at /var/lib/postgresql.","validRegex":"/.{1,}/"},{"id":"$$cap_public_url","label":"Vikunja Public URL","defaultValue":"https://$$cap_appname.$$cap_root_domain/","description":"Full public URL for Vikunja, including scheme and trailing slash.","validRegex":"/^https?:\\/\\/.+\\/$/"},{"id":"$$cap_service_secret","label":"Service Secret","default